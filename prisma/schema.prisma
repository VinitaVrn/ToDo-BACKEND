generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TodoType {
  task
  checklist
}

enum TodoStatus {
  ALL
  in_progress
  blocked
  done
  cancelled
}

enum TodoPriority {
  low
  medium
  high
  critical
}


model Todo {
  id          String      @id @default(cuid())
  title       String
  description String?

  type        TodoType     @default(task)
  status      TodoStatus   @default(ALL)
  priority    TodoPriority @default(medium)

  tags        String[]     @default([])   

  dueDate     DateTime?
  isPinned    Boolean      @default(false)
  isArchived  Boolean      @default(false)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  items       TodoItem[]
  history     TodoHistory[]

  @@index([status, priority])
  @@index([deletedAt])
  @@map("todos")
}

model TodoItem {
  id        String   @id @default(cuid())
  content   String
  isDone    Boolean  @default(false)
  position  Int      @default(0)

  todoId    String
  todo      Todo     @relation(fields: [todoId], references: [id], onDelete: Cascade)

  @@map("todo_items")
}

model TodoHistory {
  id            String   @id @default(cuid())
  changedField  String
  oldValue      String?
  newValue      String?
  changedAt     DateTime @default(now())

  todoId        String
  todo          Todo     @relation(fields: [todoId], references: [id], onDelete: Cascade)

  @@map("todo_history")
}

model User {
  id        String   @id @default(cuid())

  name      String
  email     String   @unique
  password  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  todos     Todo[]

  @@map("users")
}